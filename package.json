{
  "name": "ai-diagram-document-generator",
  "version": "1.0.0",
  "type": "module",
  "description": "AI-powered tool for generating diagrams-as-code and structured technical documents from natural language prompts",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:property": "vitest run tests/property",
    "test:integration": "vitest run tests/integration"
  },
  "dependencies": {
    "express": "^5.0.1",
    "uuid": "^11.1.1",
    "groq-sdk": "^0.12.0",
    "@google/genai": "^2.7.0",
    "mermaid": "^11.15.0",
    "markdown-it": "^14.2.0",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0",
    "tsx": "^4.22.4",
    "vitest": "^3.1.0",
    "fast-check": "^3.23.2",
    "supertest": "^7.2.2"
  },
  "packageManager": "pnpm@9.1.0"
}
