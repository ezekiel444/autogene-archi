{
  "name": "ai-diagram-document-generator",
  "version": "1.0.0",
  "type": "module",
  "description": "AI-powered tool for generating diagrams-as-code and structured technical documents from natural language prompts",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npx concurrently \"tsx watch src/index.ts\" \"cd frontend && npx vite --host\"",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "tsc && cd frontend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:property": "vitest run tests/property",
    "test:integration": "vitest run tests/integration"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "dotenv": "^17.4.2",
    "express": "^5.0.1",
    "groq-sdk": "^1.2.1",
    "markdown-it": "^14.2.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.3",
    "concurrently": "10.0.3",
    "fast-check": "^4.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@9.1.0"
}
